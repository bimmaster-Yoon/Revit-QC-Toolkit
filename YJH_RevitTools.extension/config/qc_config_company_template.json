{
  "version": "v2.10.0",
  "preset_name": "Company Template",
  "preset_description": "Template preset for company-specific QC standards.",
  "sheet_qc": {
    "require_sheet_number": true,
    "require_sheet_name": true,
    "require_placed_view": true
  },
  "view_qc": {
    "supported_view_types": [
      "FloorPlan",
      "CeilingPlan",
      "Elevation",
      "Section",
      "Detail",
      "DraftingView",
      "ThreeD"
    ],
    "template_required_view_types": [
      "FloorPlan",
      "CeilingPlan",
      "Elevation",
      "Section"
    ],
    "sheet_required_view_types": [
      "FloorPlan",
      "CeilingPlan",
      "Elevation",
      "Section",
      "Detail",
      "DraftingView"
    ],
    "temporary_keywords": [
      "Copy",
      "Temp",
      "Working",
      "TEST"
    ]
  },
  "parameter_qc": {
    "rules": [
      {
        "built_in_category": "OST_Rooms",
        "category_name": "Rooms",
        "parameter_name": "RoomType"
      }
    ]
  },
  "display": {
    "group_sample_max_length": 25,
    "group_sample_limit": 3,
    "key_issue_limit": 8,
    "key_item_max_length": 35
  },
  "export": {
    "file_prefix": "Revit_QC_Company"
  }
}
