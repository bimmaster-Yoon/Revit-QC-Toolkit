      "FloorPlan",
      "CeilingPlan",
      "Elevation",
      "Section",
      "Detail",
      "DraftingView",
      "ThreeD"
    ],
    "template_required_view_types": [
      "FloorPlan",
      "CeilingPlan",
      "Elevation",
      "Section"
    ],
    "sheet_required_view_types": [
      "FloorPlan",
      "CeilingPlan",
      "Elevation",
      "Section",
      "Detail",
      "DraftingView"
    ],
    "temporary_keywords": [
      "Copy",
      "복사",
      "Temp",
