# Revit files
*.rvt
*.rfa
*.rte
*.rft
*.bak
*.slog
*.*.rvt
*.*.rfa

# Large compressed files
*.zip
*.7z
*.rar

# CSV exports
*.csv
!sample_output/*.csv

# Excel exports
*.xlsx

# PDF exports
*.pdf

# Python cache
__pycache__/
*.pyc

# Temporary files
*.tmp
*.temp
~$*
Thumbs.db
desktop.ini

# Logs
*.log

# Sensitive project data
private/
source_rvt/
real_project_files/
screenshots/raw/
portfolio_assets/

# Local machine configuration
YJH_RevitTools.extension/config/qc_config_local.json
/config/qc_config_local.json

# Locally duplicated QC rule sets
YJH_RevitTools.extension/config/qc_config_custom_*.json
/config/qc_config_custom_*.json

# Runtime report history
YJH_RevitTools.extension/reports/*
!YJH_RevitTools.extension/reports/.gitkeep
YJH_RevitTools.extension/reports/latest_report_path.txt
YJH_RevitTools.extension/reports/latest_export_folder.txt
/reports/*
!/reports/.gitkeep
/reports/latest_report_path.txt
/reports/latest_export_folder.txt

# Generated release packages
release/
dist/

# Development-only probe tools
YJH_RevitTools.extension/tools/dev/

# Documentation images must remain trackable
!docs/images/
!docs/images/**/*.png
!docs/images/**/*.jpg
!docs/images/**/*.jpeg
!docs/images/**/*.webp
